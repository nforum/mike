PORT=3001
FRONTEND_URL=http://localhost:3000
# Externally-reachable backend URL. Used to build the OAuth callback URL for
# MCP connectors. Defaults to http://localhost:${PORT} when unset.
BACKEND_PUBLIC_URL=http://localhost:3001

# ── Database (Cloud SQL) ─────────────────────────────────────────────────
# Production: set CLOUD_SQL_CONNECTION_NAME + DB_IAM_USER for IAM auth via
# the Cloud SQL Node.js Connector (no password needed).
CLOUD_SQL_CONNECTION_NAME=mikeoss-495610:europe-west1:mike-db
DB_IAM_USER=mike-backend@mikeoss-495610.iam
DB_NAME=mike

# Development: set DATABASE_URL (overrides Cloud SQL Connector).
# Use Cloud SQL Auth Proxy: cloud-sql-proxy mikeoss-495610:europe-west1:mike-db --port 5433
DATABASE_URL=postgresql://mike_app:MikeOSS-Bootstrap-2026!@127.0.0.1:5433/mike

# ── Auth ─────────────────────────────────────────────────────────────────
EULEX_MCP_JWT_SECRET=your-jwt-signing-secret

# ── Object Storage (Cloudflare R2) ───────────────────────────────────────
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=mike

# ── AI / LLM API Keys ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
OPENROUTER_API_KEY=your-openrouter-key
RESEND_API_KEY=your-resend-key

# ── vLLM (OpenAI-compatible endpoint) ────────────────────────────────────
VLLM_BASE_URL=https://your-vllm-endpoint.com/v1
VLLM_API_KEY=your-vllm-api-key
VLLM_MAIN_MODEL=BredaAI
VLLM_LIGHT_MODEL=your-light-model-name
