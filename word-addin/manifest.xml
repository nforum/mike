<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
    xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
    xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
    xsi:type="TaskPaneApp">

    <Id>81398f3a-bb02-4f19-a20f-3c83fa7ffd64</Id>
    <Version>1.0.0.0</Version>
    <ProviderName>eulex.ai</ProviderName>
    <DefaultLocale>en-US</DefaultLocale>
    <!-- Per Microsoft store guidelines, the DisplayName is the short product
         name only (no "for Word", no company name). -->
    <DisplayName DefaultValue="Max"/>
    <Description DefaultValue="AI legal document assistant for Microsoft Word."/>
    <IconUrl DefaultValue="${ADDIN_URL}/word-addin/assets/icon-64.png"/>
    <HighResolutionIconUrl DefaultValue="${ADDIN_URL}/word-addin/assets/icon-128.png"/>
    <SupportUrl DefaultValue="${ADDIN_URL}/account/word"/>

    <!-- AppDomains is only required if the add-in navigates to another origin
         (e.g. an OAuth provider). The Max taskpane stays on its own origin
         and proxies all auth via the backend, so this list stays empty. -->
    <AppDomains>
        <AppDomain>${ADDIN_URL}</AppDomain>
    </AppDomains>

    <Hosts>
        <Host Name="Document"/>
    </Hosts>

    <Requirements>
        <Sets DefaultMinVersion="1.1">
            <Set Name="WordApi" MinVersion="1.4"/>
        </Sets>
    </Requirements>

    <DefaultSettings>
        <SourceLocation DefaultValue="${ADDIN_URL}/word-addin/taskpane.html"/>
    </DefaultSettings>

    <!-- ReadWriteDocument is required for tracked changes and comments. -->
    <Permissions>ReadWriteDocument</Permissions>

    <VersionOverrides
        xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
        xsi:type="VersionOverridesV1_0">
        <Hosts>
            <Host xsi:type="Document">
                <DesktopFormFactor>
                    <GetStarted>
                        <Title resid="GetStarted.Title"/>
                        <Description resid="GetStarted.Description"/>
                        <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
                    </GetStarted>
                    <ExtensionPoint xsi:type="PrimaryCommandSurface">
                        <OfficeTab id="TabHome">
                            <Group id="MikeAIGroup">
                                <Label resid="CommandsGroup.Label"/>
                                <Icon>
                                    <bt:Image size="16" resid="Icon.16x16"/>
                                    <bt:Image size="32" resid="Icon.32x32"/>
                                    <bt:Image size="80" resid="Icon.80x80"/>
                                </Icon>
                                <Control xsi:type="Button" id="MikeAIButton">
                                    <Label resid="TaskpaneButton.Label"/>
                                    <Supertip>
                                        <Title resid="TaskpaneButton.Label"/>
                                        <Description resid="TaskpaneButton.Tooltip"/>
                                    </Supertip>
                                    <Icon>
                                        <bt:Image size="16" resid="Icon.16x16"/>
                                        <bt:Image size="32" resid="Icon.32x32"/>
                                        <bt:Image size="80" resid="Icon.80x80"/>
                                    </Icon>
                                    <Action xsi:type="ShowTaskpane">
                                        <TaskpaneId>MikeAIPane</TaskpaneId>
                                        <SourceLocation resid="Taskpane.Url"/>
                                    </Action>
                                </Control>
                            </Group>
                        </OfficeTab>
                    </ExtensionPoint>
                </DesktopFormFactor>
            </Host>
        </Hosts>
        <Resources>
            <bt:Images>
                <bt:Image id="Icon.16x16" DefaultValue="${ADDIN_URL}/word-addin/assets/icon-16.png"/>
                <bt:Image id="Icon.32x32" DefaultValue="${ADDIN_URL}/word-addin/assets/icon-32.png"/>
                <bt:Image id="Icon.80x80" DefaultValue="${ADDIN_URL}/word-addin/assets/icon-64.png"/>
            </bt:Images>
            <bt:Urls>
                <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="${ADDIN_URL}/account/word"/>
                <bt:Url id="Taskpane.Url" DefaultValue="${ADDIN_URL}/word-addin/taskpane.html"/>
            </bt:Urls>
            <bt:ShortStrings>
                <bt:String id="GetStarted.Title" DefaultValue="Get started with Max"/>
                <bt:String id="CommandsGroup.Label" DefaultValue="Max"/>
                <bt:String id="TaskpaneButton.Label" DefaultValue="Open Max"/>
            </bt:ShortStrings>
            <bt:LongStrings>
                <bt:String id="GetStarted.Description" DefaultValue="Your AI-powered legal document assistant inside Word."/>
                <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the Max sidebar"/>
            </bt:LongStrings>
        </Resources>
    </VersionOverrides>
</OfficeApp>
