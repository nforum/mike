# Copy to .env and fill in your values

# Max backend base URL.
# Leave empty in production to use the same origin as the taskpane (the
# frontend host that serves /word-addin/taskpane.html). Set explicitly
# during local dev when the backend runs on a different port.
API_BASE_URL=http://localhost:3001

# Public HTTPS URL where the taskpane bundle will be hosted. Used to
# substitute ${ADDIN_URL} in manifest.xml during build.
# Dev:  https://localhost:3002
# Prod: https://<your-frontend-domain>
ADDIN_URL=https://localhost:3002
