# Files NOT uploaded to Cloud Build when running `gcloud builds submit`.
# Keep this list tight — every MB counts toward the upload step.

.git
.gitignore
.cursor
.vscode
.DS_Store

# Per-package node_modules — Cloud Build re-installs from package-lock.json.
**/node_modules

# Build output that gets regenerated inside the build steps.
**/dist
**/.next
**/out
**/build
**/.open-next
frontend/public/word-addin

# Local env files — never push secrets through Cloud Build.
#
# .env.production is allow-listed because `scripts/deploy.sh` writes it
# (containing only public NEXT_PUBLIC_* values) right before invoking
# `gcloud run deploy --source frontend`, so Next.js can inline the API
# URL into the client bundle at build time. The file is removed again
# as soon as the deploy returns; it is never committed.
.env
.env.*
!.env.example
!.env.local.example
!frontend/.env.production
# Same file when `--source frontend` archives this dir with paths relative
# to frontend/ (no `frontend/` prefix) — see frontend/.gcloudignore too.
!**/.env.production

# Logs & misc
*.log
*.tsbuildinfo
.next-env.d.ts
coverage

# Standalone PHP integration files (lived alongside the repo for reference).
vanjske_datoteke/

# Saved chat transcripts/screenshots used while iterating locally.
docs/screenshots
