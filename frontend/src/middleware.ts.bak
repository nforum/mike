import createMiddleware from "next-intl/middleware";
import { locales, defaultLocale } from "@/i18n/request";

export default createMiddleware({
    locales,
    defaultLocale,
    localeDetection: false,
    localePrefix: "never",
});

export const config = {
    // Skip API routes, Next internals, and static assets
    matcher: ["/((?!api|_next|.*\\..*).*)"],
};
